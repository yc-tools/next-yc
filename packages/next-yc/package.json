{
  "name": "@yc-tools/next-yc",
  "version": "1.0.0",
  "description": "CLI tool for deploying Next.js apps to Yandex Cloud",
  "license": "MIT",
  "author": "yc-tools Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/yc-tools/next-yc.git",
    "directory": "packages/next-yc"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "next-yc": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp src/compat/compat.yml dist/compat/compat.yml && cp -r src/terraform/project dist/terraform/project && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "pnpm --filter @yc-tools/next-yc-runtime build && vitest run --passWithNoTests",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint 'src/**/*.ts' --max-warnings 0 || true",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/lib-storage": "^3.1026.0",
    "@yc-tools/next-yc-runtime": "workspace:*",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "esbuild": "^0.28.0",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0",
    "semver": "^7.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/semver": "^7.7.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
